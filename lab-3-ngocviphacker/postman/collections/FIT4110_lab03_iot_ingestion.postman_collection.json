    },
    {
      "name": "03_Consumer-side Smoke Tests",
      "item": [
        {
          "name": "Consumer smoke - Core can consume latest sensor readings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Prefer",
                "value": "code=200"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/latest?limit=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings",
                "latest"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "1"
                }
              ]
            },
            "description": "Ví dụ smoke test phía consumer. Nhóm Core/Analytics có thể dùng mock IoT để phát triển trước khi IoT code xong."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Consumer receives 200 from provider mock', function () { pm.response.to.have.status(200); });",
                  "pm.test('Consumer can parse items', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});",
                  "pm.test('Provider mock URL is documented', function () {",
                  "  pm.expect(pm.environment.get('baseUrl')).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}