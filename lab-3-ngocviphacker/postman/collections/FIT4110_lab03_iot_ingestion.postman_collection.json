{
  "info": {
    "_postman_id": "fit4110-lab03-iot-ingestion",
    "name": "FIT4110 Lab03 - IoT Ingestion Contract Tests",
    "description": "Postman Collection mẫu cho Buổi 3: Mock Server, provider-side tests, consumer-side smoke tests và Newman evidence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.variables.set('traceId', 'trace-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4010"
    },
    {
      "key": "authToken",
      "value": "lab-token"
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - service is alive",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Prefer",
                "value": "code=200"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has service status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Provider-side Contract Tests",
      "item": [
        {
          "name": "POST /readings - happy path 201",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Prefer",
                "value": "code=201"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has reading_id and accepted=true', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('reading_id');",
                  "  pm.expect(json.accepted).to.eql(true);",
                  "});",
                  "pm.test('Response time is acceptable', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /readings - validation error 400",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Prefer",
                "value": "code=400"
