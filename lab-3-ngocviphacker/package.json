{
  "name": "fit4110_lab03_postman_mock_testing",
  "version": "0.3.0",
  "private": true,
  "description": "FIT4110 Lab 03 - Postman, Mock Server, Contract Testing, Newman CI",
  "scripts": {
    "mock:iot": "prism mock contracts/iot-ingestion.openapi.yaml -p 4010 --host 0.0.0.0",
    "mock:notify": "prism mock lab02-ngocviphacker/openapi.yaml -p 4010 --host 0.0.0.0",
    "test:mock": "newman run postman/collections/FIT4110_lab03_iot_ingestion.postman_collection.json -e postman/environments/FIT4110_lab03_mock.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-mock.xml",
    "test:local": "newman run postman/collections/FIT4110_lab03_iot_ingestion.postman_collection.json -e postman/environments/FIT4110_lab03_local.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-local.xml",
    "test:mock:notify": "newman run postman/collections/team-notify.postman_collection.json -e postman/environments/team-notify_mock.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-notify-mock.xml",
    "test:local:notify": "newman run postman/collections/team-notify.postman_collection.json -e postman/environments/team-notify_local.postman_environment.json --reporters cli,junit --reporter-junit-export reports/newman-report-notify-local.xml",
    "test:html": "newman run postman/collections/FIT4110_lab03_iot_ingestion.postman_collection.json -e postman/environments/FIT4110_lab03_mock.postman_environment.json --reporters cli,htmlextra --reporter-htmlextra-export reports/newman-report.html"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}
